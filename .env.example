PORT=3000
KAFKA_BROKER=kafka:9092
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
INNGEST_DEV=1
INNGEST_BASE_URL=http://inngest-dev:8288
INNGEST_SERVE_HOST=http://app:3000
INNGEST_EVENT_KEY=local-dev-event-key
INNGEST_SIGNING_KEY=local-dev-signing-key

# Shopify Configuration
SHOPIFY_SHOP_DOMAIN=your-store-name.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
SHOPIFY_OAUTH_PORT=53682
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_permanent_token_here
SHOPIFY_API_VERSION=2026-04

# Inventory delta push
CRITICAL_STOCK_THRESHOLD=0