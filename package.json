{
  "name": "wms-mvp-local",
  "version": "1.0.0",
  "description": "Shopify webhook to WMS event pipeline MVP",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate",
    "test:stress:build": "tsc -p tests/tsconfig.json && node -e \"require('fs').copyFileSync('tests/build/stress-test.js','tests/stress-test.js')\"",
    "test:stress": "npm run test:stress:build && k6 run tests/stress-test.js",
    "shopify:token": "tsx scripts/get-shopify-token.ts",
    "test:inventory-change": "tsx scripts/publish-inventory-change.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@bull-board/api": "^5.23.0",
    "@bull-board/express": "^5.23.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.8",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "inngest": "^3.27.5",
    "ioredis": "^5.4.2",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/k6": "^0.57.0",
    "@types/node": "^22.10.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
