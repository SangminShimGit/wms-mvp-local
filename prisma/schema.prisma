generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WmsOrder {
  id        Int      @id @default(autoincrement())
  shopifyId String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WmsInventory {
  id        Int      @id @default(autoincrement())
  sku       String   @unique
  stock     Int
  location  String
  isSynced  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WmsInventoryChange {
  id              BigInt   @id @default(autoincrement())
  sku             String
  locationName    String
  deltaQty        Int
  isShopifyPushed Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([isShopifyPushed, sku])
  @@map("wms_inventory_changes")
}
